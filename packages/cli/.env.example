# Spectrl CLI Configuration
#
# This file shows available configuration options.
# Copy this to .env to customize your local development environment.

# ============================================================================
# Runtime Configuration (optional)
# ============================================================================
# These variables override the build-time defaults when set at runtime

# API URL for the public registry
# If not set, uses the default from .env.production (injected at build time)
# API_URL=https://YOUR_API_GATEWAY_ID.execute-api.YOUR_REGION.amazonaws.com/prod

# Registry URL for downloading specs
# This is typically fetched from API responses, but can be overridden
# REGISTRY_URL=https://YOUR_S3_BUCKET.s3.YOUR_REGION.amazonaws.com

# ============================================================================
# Development/Testing
# ============================================================================
# Uncomment to test against LocalStack or other environments
# API_URL=http://localhost:4566/restapis/{api_id}/dev/_user_request_
# REGISTRY_URL=http://localhost:4566/spectrl-registry-dev

# ============================================================================
# Build-Time Configuration
# ============================================================================
# See .env.production for build-time defaults that are injected into the CLI
# These are committed to the repository and used during `pnpm build`

