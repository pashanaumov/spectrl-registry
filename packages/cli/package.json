{
  "name": "spectrl-registry",
  "version": "0.2.0",
  "description": "Local-first spec registry - CLI for managing versioned, composable structured documents",
  "type": "module",
  "bin": {
    "spr": "dist/cli.js"
  },
  "exports": {
    "./dist/cli.js": "./dist/cli.js",
    "./commands/*": "./dist/commands/*.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsx build.ts",
    "build:tsc": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "keywords": [
    "spectrl",
    "cli",
    "spec",
    "registry",
    "local-first",
    "package-manager",
    "documentation",
    "prd",
    "tdd",
    "adr",
    "agent-readable"
  ],
  "author": "Pasha Naumov",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "cmd-ts": "^0.13.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "fs-extra": "^11.3.2",
    "keytar": "^7.9.0",
    "node-machine-id": "^1.1.12",
    "open": "^11.0.0",
    "ora": "^9.0.0",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@spectrl/core": "workspace:*",
    "@spectrl/schema": "workspace:*",
    "@types/bun": "^1.3.1",
    "@types/fs-extra": "^11.0.4",
    "@types/keytar": "^4.4.2",
    "@types/semver": "^7.7.1",
    "fast-check": "^4.5.3",
    "msw": "^2.12.4"
  }
}
