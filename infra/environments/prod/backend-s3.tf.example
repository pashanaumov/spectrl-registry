# This is an example of what backend.tf should look like after migrating to S3
# 
# Steps to migrate:
# 1. First apply the state-backend infrastructure: cd state-backend && terraform apply
# 2. Copy this file content to backend.tf
# 3. Run: terraform init -migrate-state
# 4. Type 'yes' when prompted to migrate state

terraform {
  backend "s3" {
    bucket         = "spectrl-terraform-state-prod"
    key            = "terraform.tfstate"
    region         = "eu-north-1"
    dynamodb_table = "spectrl-terraform-locks-prod"
    encrypt        = true
  }
}
