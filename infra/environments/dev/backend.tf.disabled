terraform {
  backend "s3" {
    bucket         = "spectrl-terraform-state-dev"
    key            = "terraform.tfstate"
    region         = "eu-north-1"
    dynamodb_table = "spectrl-terraform-locks-dev"
    encrypt        = true

    # LocalStack-specific settings
    skip_credentials_validation = true
    skip_metadata_api_check     = true
    skip_requesting_account_id  = true
    
    # When using tflocal, endpoints are configured automatically
    # Don't specify endpoints here - let tflocal handle it
  }
}
